{
  "name": "personal-cv",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev dist --d1 DB=personal-website-db",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "wrangler d1 execute personal-website-db --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute personal-website-db --remote --file=migrations/0001_init.sql",
    "save": "sh -c 'git add src/ public/ index.html package.json vite.config.js && { git diff --cached --quiet && echo \"Nothing new to commit, pushing anyway...\" || git commit -m \"update: $(date \"+%Y-%m-%d %H:%M\")\"; } && git push'"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "wrangler": "4.98.0"
  }
}
